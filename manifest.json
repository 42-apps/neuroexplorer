{
  "manifest_version": 3,
  "name": "NeuroExplorer — 3D Human Brain",
  "version": "0.1.0",
  "description": "Interactive, evidence-based 3D explorer of the human brain: anatomy, lifespan, disease, senses, and neurons firing.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open NeuroExplorer — 3D Brain",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
