# so these patterns must sit on their own lines).
# _betadist: public beta tree (tools/build-beta.cjs) — actually emitted to ../neuroexplorer-beta-dist
_betadist/
# dist: store-package artifacts (tools/build-store.cjs), incl. the ~61 MB zip
dist/
# sibling build trees created next to the repo
neuroexplorer-store-dist/
