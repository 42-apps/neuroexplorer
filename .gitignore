# Project policy: the repo is fully self-contained — ALL code AND data is committed.
# (Keep the repo PRIVATE: assets/propack/ is the purchased CGTrader pack — royalty-free
#  for use, but not for public redistribution as a raw asset.)
node_modules/
.DS_Store
